endif
if class($n)==blackbelt
mpat hvak2 mpfor hvak2 answer A blackbelt in the arts, $n.
endif
if class($n)==ranger
mpat hvak2 mpfor hvak2 answer A courageous ranger, $n.
mpoload 13311 1
endif
if class($n)==warrior
mpat hvak2 mpfor hvak2 answer A robust warrior, $n.
mpoload 13312 1
endif
if class($n)==druid
mpat hvak2 mpfor hvak2 answer A mystic druid, $n.
mpoload 13313 1
endif
if class($n)==cleric
mpat hvak2 mpfor hvak2 answer A pious cleric, $n.
mpoload 13313 1
endif
if class($n)==mage
mpat hvak2 mpfor hvak2 answer A sorcerous mage, $n.
mpoload 13311 1
endif
if class($n)==thief
mpat hvak2 mpfor hvak2 answer A cunning thief, $n.
mpoload 13311 1
endif
if class($n)==vampire
mpat hvak2 mpfor hvak2 answer A shadowy vampire, $n.
mpoload 13311 1
endif
if class($n)==augurer
mpat hvak2 mpfor hvak2 answer A visionary augurer, $n.
mpoload 13312 1
endif
give academy $n
mpforce $n wield academy
endif
tell 0.$n May the Gods be with you.
mppkset $n yes
endif
~
> speech_prog p school~
mptransfer 0.$n 11701
mpat 11701 mpforce 0.$n look
mpecho $n has left to the Amethyst Mud School.
~
> act_prog p has entered the game.~
if race($n) == wyvern
mpechoat $n _red Sorry, but Wyvern's are not allowed yet.
mpechoat $n _red We're sorry for the inconvenience but ban is not working currently...  Please log in again.
mpforce $n quit
endif
~
