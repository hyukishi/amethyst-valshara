> speech_prog key~
if name($n) == God
or name($n) == Xero
mpoload 10202
give key $n
else
mptransfer $n 6
endif
~
> all_greet_prog 100~
if name($n) == Xero
or name($n) == God
else
mptransfer $n 6
mpoload 10202
lock cab
eat key
endif
~
> act_prog p sits on an office chair.~
if name($n) == Xero
or name($n) == God
else
mpechoat $n You suddenly realize that might not be the greatest idea...
mpforce $n stand
endif
~
